APP_NAME=tkk-UniversalValidator API
APP_VERSION=0.2.0
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENABLE_GZIP=true
ENABLE_SECURITY_HEADERS=true
ENABLE_RATE_LIMIT_HOOKS=true
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tkk_uv
DATABASE_ENABLED=false
DATABASE_REQUIRED=false
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
REDIS_REQUIRED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_ENABLED=false
CELERY_REQUIRED=false
REQUEST_ID_HEADER=X-Request-ID
JWT_SECRET_KEY=change_me_please_use_32_characters_min
JWT_ISSUER=tkk-uv
JWT_AUDIENCE=tkk-uv-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
CSRF_ENABLED=true
CSRF_HEADER_NAME=X-CSRF-Token
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_AZURE_AD_CLIENT_ID=
OAUTH_AZURE_AD_CLIENT_SECRET=
OAUTH_OKTA_CLIENT_ID=
OAUTH_OKTA_CLIENT_SECRET=
LDAP_ENABLED=false
SAML_ENABLED=false
CONFIG_ENCRYPTION_KEY=change_me_config_encryption_key_32_char_min
SECRET_CACHE_TTL_SECONDS=300
CONFIG_ENV_PREFIX=CFG_
DOTENV_SOURCE_PATH=.env
YAML_SOURCE_PATH=config/examples/config_sources.yaml
AWS_SECRETS_MANAGER_BLOB=
AZURE_KEY_VAULT_BLOB=
GOOGLE_SECRET_MANAGER_BLOB=
HASHICORP_VAULT_BLOB=
